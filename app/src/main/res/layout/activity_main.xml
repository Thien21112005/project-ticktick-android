<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/bg_light_gray">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="72dp"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:elevation="8dp"> <androidx.cardview.widget.CardView
        android:id="@+id/nav_avatar"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="24dp" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:src="@drawable/ic_launcher_background" /> </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/top_menu_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/nav_avatar">

            <ImageView
                android:id="@+id/btn_nav_task"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginBottom="32dp"
                android:src="@android:drawable/checkbox_on_background"
                app:tint="@color/red_primary"/> <ImageView
            android:id="@+id/btn_nav_calendar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_marginBottom="32dp"
            android:src="@android:drawable/ic_menu_today"
            app:tint="@color/icon_inactive"/>

            <ImageView
                android:id="@+id/btn_nav_search"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="@color/icon_inactive"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <ImageView
                android:id="@+id/btn_nav_sync"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginBottom="32dp"
                android:src="@android:drawable/ic_popup_sync"
                app:tint="@color/icon_inactive"/>

            <ImageView
                android:id="@+id/btn_nav_notification"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginBottom="32dp"
                android:src="@android:drawable/ic_dialog_info"
                app:tint="@color/icon_inactive"/>

            <ImageView
                android:id="@+id/btn_nav_help"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_menu_help"
                app:tint="@color/icon_inactive"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1" />
</LinearLayout>