<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA"
    android:paddingTop="16dp"
    android:paddingBottom="24dp"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/menu_item_today"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:paddingHorizontal="24dp"> <ImageView
        android:id="@+id/icon_today"
        android:layout_width="24dp"
        android:layout_height="24dp"
        app:tint="#424242"
        android:src="@android:drawable/ic_menu_my_calendar"/>

        <TextView
            android:id="@+id/text_today"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Today"
            android:textSize="16sp"
            android:textColor="#222222"
            android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_item_next_7_days"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:paddingHorizontal="24dp">

        <ImageView
            android:id="@+id/icon_7days"
            android:layout_width="24dp"
            android:layout_height="24dp"
            app:tint="#424242"
            android:src="@android:drawable/ic_menu_month"/>

        <TextView
            android:id="@+id/text_7days"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Next 7 Days"
            android:textColor="#222222"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/menu_item_inbox"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:paddingHorizontal="24dp">

        <ImageView
            android:id="@+id/icon_inbox"
            android:layout_width="24dp"
            android:layout_height="24dp"
            app:tint="#424242"
            android:src="@android:drawable/ic_dialog_email"/>

        <TextView
            android:id="@+id/text_inbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Inbox"
            android:textColor="#222222"
            android:textSize="16sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginHorizontal="24dp"
        android:layout_marginVertical="12dp"
        android:background="#E0E0E0" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:clickable="true"
        android:background="?attr/selectableItemBackground"
        android:paddingHorizontal="24dp">

        <ImageView
            android:id="@+id/icon_arrow_lists"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/arrow_down_float"
            app:tint="#9E9E9E"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/icon_arrow_lists"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:text="LISTS"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:textSize="13sp"
            android:textColor="#757575"
            android:textStyle="bold"/>

        <ImageView
            android:id="@+id/btn_add_list"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_input_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#757575"/>
    </RelativeLayout>

    <LinearLayout
        android:id="@+id/layout_dynamic_lists"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="56dp"
        android:paddingEnd="24dp"
        android:paddingTop="4dp"
        android:paddingBottom="8dp">
    </LinearLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:clickable="true"
        android:background="?attr/selectableItemBackground"
        android:paddingHorizontal="24dp">

        <ImageView
            android:id="@+id/icon_arrow_filters"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/arrow_down_float"
            app:tint="#9E9E9E"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/icon_arrow_filters"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:text="FILTERS"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:textSize="13sp"
            android:textColor="#757575"
            android:textStyle="bold"/>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_input_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#757575"/>
    </RelativeLayout>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:clickable="true"
        android:background="?attr/selectableItemBackground"
        android:paddingHorizontal="24dp">

        <ImageView
            android:id="@+id/icon_arrow_tags"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/arrow_down_float"
            app:tint="#9E9E9E"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/icon_arrow_tags"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:text="TAGS"
            android:textAllCaps="true"
            android:letterSpacing="0.05"
            android:textSize="13sp"
            android:textColor="#757575"
            android:textStyle="bold"/>

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/ic_input_add"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="#757575"/>
    </RelativeLayout>

</LinearLayout>
</ScrollView>